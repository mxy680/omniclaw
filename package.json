{
  "name": "@openclaw/omniclaw",
  "version": "2026.3.2",
  "private": true,
  "description": "Google Workspace and YouTube MCP server for OpenClaw",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "mcp": "node dist/mcp-server.js",
    "mcp:dev": "tsx src/mcp-server.ts",
    "test": "vitest run --exclude 'tests/integration/**'",
    "test:watch": "vitest --exclude 'tests/integration/**'",
    "test:integration": "vitest run tests/integration",
    "test:smoke": "vitest run tests/integration/smoke.test.ts",
    "web:dev": "pnpm --filter @openclaw/omniclaw-web dev",
    "web:build": "pnpm --filter @openclaw/omniclaw-web build",
    "web:test": "pnpm --filter @openclaw/omniclaw-web test"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@octokit/rest": "^22.0.1",
    "@sinclair/typebox": "0.34.48",
    "croner": "^10.0.1",
    "express": "^5.2.1",
    "google-auth-library": "^10.5.0",
    "googleapis": "^144.0.0",
    "mime-types": "^3.0.2",
    "open": "^10.1.0",
    "youtube-transcript": "^1.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^20.0.0",
    "openclaw": "*",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.12.3+sha512.cce0f9de9c5a7c95bef944169cc5dfe8741abfb145078c0d508b868056848a87c81e626246cb60967cbd7fd29a6c062ef73ff840d96b3c86c40ac92cf4a813ee"
}
